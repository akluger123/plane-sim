<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>3D Browser Flight Sim</title>
    <script src="https://cesium.com/downloads/cesiumjs/releases/1.110/Build/Cesium/Cesium.js"></script>
    <link href="https://cesium.com/downloads/cesiumjs/releases/1.110/Build/Cesium/Widgets/widgets.css" rel="stylesheet">
    <style>
        body, html, #cesiumContainer { width: 100%; height: 100%; margin: 0; padding: 0; overflow: hidden; background: #000; }
        #hud { position: absolute; top: 20px; left: 20px; color: #00ff00; font-family: 'monospace'; 
               background: rgba(0, 0, 0, 0.7); padding: 15px; border: 1px solid #00ff00; pointer-events: none; z-index: 10; }
        .ctrl-hint { font-size: 11px; color: #00cc00; margin-top: 10px; border-top: 1px solid #004400; padding-top: 5px; }
    </style>
</head>
<body>
    <div id="cesiumContainer"></div>
    <div id="hud">
        <div>SPD: <span id="speed">0</span> KNTS</div>
        <div>ALT: <span id="alt">0</span> FT</div>
        <div class="ctrl-hint">
            W/S: PITCH | A/D: ROLL<br>
            SHIFT: THRUST | CTRL: BRAKE
        </div>
    </div>

<script>
// 1. YOUR TOKEN
Cesium.Ion.defaultAccessToken = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJqdGkiOiI2NmUzZmIwNS00YTQyLTQ5ODUtOTNkMi05N2M2OGI0OWQ3MjUiLCJpZCI6NDI0MzM5LCJpYXQiOjE3NzczMDQxMzF9.s-jvG5s5JNYoyyvIKK6GPHIS3L3sDAZQrcNHJAJA1MU';

// 2. Initialize the 3D World
const viewer = new Cesium.Viewer('cesiumContainer', {
    terrainProvider: Cesium.createWorldTerrainAsync ? Cesium.createWorldTerrainAsync() : Cesium.createWorldTerrain(),
    animation: false, timeline: false, infoBox: false, selectionIndicator: false,
    baseLayerPicker: false, sceneModePicker: false
});

// 3. Add Buildings (Google 3D Tiles)
async function setupWorld() {
    try {
        const tileset = await Cesium.Cesium3DTileset.fromIonAssetId(2275207);
        viewer.scene.primitives.add(tileset);
    } catch (error) {
        viewer.scene.primitives.add(Cesium.createOsmBuildings());
    }
}
setupWorld();

// 4. Flight State
let speed = 0;
let position = Cesium.Cartesian3.fromDegrees(-122.4194, 37.7749, 1000);
let hpRoll = new Cesium.HeadingPitchRoll(0, 0, 0);

// Spawn Plane
const planeModel = 'https://raw.githubusercontent.com/CesiumGS/cesium/main/Apps/SampleData/models/CesiumAir/Cesium_Air.glb';
const plane = viewer.entities.add({
    position: position,
    orientation: Cesium.Transforms.headingPitchRollQuaternion(position, hpRoll),
    model: { uri: planeModel, minimumPixelSize: 128 }
});

// Keyboard Input
const keys = {};
window.onkeydown = (e) => keys[e.code] = true;
window.onkeyup = (e) => keys[e.code] = false;

// 5. Game Loop
viewer.scene.preUpdate.addEventListener((scene, time) => {
    // Physics inputs
    if (keys['ShiftLeft']) speed += 0.1;
    if (keys['ControlLeft']) speed = Math.max(0, speed - 0.1);
    
    if (keys['KeyW']) hpRoll.pitch -= 0.02;
    if (keys['KeyS']) hpRoll.pitch += 0.02;
    if (keys['KeyA']) hpRoll.roll -= 0.04;
    if (keys['KeyD']) hpRoll.roll += 0.04;
    
    // Auto-leveling/Drift
    hpRoll.roll *= 0.95; 
    hpRoll.heading += (hpRoll.roll * 0.05);

    // Calculate velocity vector
    const rotationMatrix = Cesium.Matrix3.fromHeadingPitchRoll(hpRoll);
    const direction = Cesium.Matrix3.multiplyByVector(rotationMatrix, Cesium.Cartesian3.UNIT_X, new Cesium.Cartesian3());
    const velocity = Cesium.Cartesian3.multiplyByScalar(direction, speed, new Cesium.Cartesian3());
    
    // Update position
    Cesium.Cartesian3.add(position, velocity, position);
    
    // Update entity
    plane.position = position;
    plane.orientation = Cesium.Transforms.headingPitchRollQuaternion(position, hpRoll);

    // Update camera to follow
    viewer.camera.lookAt(position, new Cesium.Cartesian3(-60, 0, 15));
    viewer.camera.lookAtTransform(Cesium.Matrix4.IDENTITY);

    // UI Updates
    document.getElementById('speed').innerText = Math.floor(speed * 20);
    const carto = Cesium.Cartographic.fromCartesian(position);
    document.getElementById('alt').innerText = Math.floor(carto.height * 3.28);
});
</script>
</body>
</html>